{
	"name": "ganban",
	"version": "0.1.4",
	"description": "A Minecraft Bedrock Addon Compiler that does little more than copy folders",
	"author": "Lucked Coronet",
	"license": "MIT",
	"keywords": [
		"minecraft",
		"compiler",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LuckedCoronet/ganban.git"
	},
	"scripts": {
		"types": "tsc --noEmit",
		"build": "tsc --noEmit && tsx scripts/build.ts",
		"build:watch": "tsx scripts/build-watch.ts"
	},
	"type": "module",
	"main": "dist/lib.js",
	"types": "dist/lib.d.ts",
	"bin": {
		"ganban": "dist/cli.js"
	},
	"os": [
		"win32"
	],
	"packageManager": "pnpm@10.6.3",
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.13.10",
		"typescript": "^5.8.2"
	},
	"dependencies": {
		"@inquirer/prompts": "^7.4.0",
		"chalk": "^5.4.1",
		"chokidar": "^4.0.3",
		"commander": "^13.1.0",
		"cosmiconfig": "^9.0.0",
		"esbuild": "^0.25.1",
		"fs-extra": "^11.3.0",
		"json5": "^2.2.3",
		"tsx": "^4.19.3",
		"zod": "^3.24.2"
	}
}
